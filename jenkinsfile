pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                bat 'docker build -t qr-app .'
            }
        }
        stage('Deploy') {
            steps {
                bat 'docker rm -f qr-container || true'
                bat 'docker run -d -p 3000:3000 --name qr-container qr-app'
            }
        }
    }
}
